# Optional server-side OpenAI key (see also repo-root `.env`).
OPENAI_API_KEY=

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/polymath

# Neo4j (concept graph). Leave unset to disable graph writes (curator no-ops).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=polymath-dev

# Set MOCK_MODEL=true to bypass OpenAI entirely and use built-in fixture data
# (useful for smoke tests / UI work without burning tokens). Leave unset or
# false for real model calls.
MOCK_MODEL=false
OPENAI_MODEL=gpt-5.2
OPENAI_MODEL_CURATOR=gpt-5.2-mini
