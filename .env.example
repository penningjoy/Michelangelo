# Copy to `.env` or `apps/web/.env.local` and fill in locally. Do not commit secrets.
# Optional: server-side key (skips the browser key screen when set).
OPENAI_API_KEY=

OPENAI_MODEL=gpt-5.2
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/polymath
POSTGRES_SSL_NO_VERIFY=false
MOCK_MODEL=true

# Cache backend. Optional. Picks one of: memory | postgres | redis.
# When unset: auto — Postgres if a DB is available, otherwise in-memory.
# CACHE_DRIVER=redis
# REDIS_URL=redis://localhost:6379
