{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "uv sync",
      "type": "shell",
      "command": "UV_CACHE_DIR=.uv-cache uv sync --extra dev",
      "problemMatcher": []
    },
    {
      "label": "canvas install",
      "type": "shell",
      "command": "npm install --prefix apps/canvas",
      "problemMatcher": []
    },
    {
      "label": "canvas build",
      "type": "shell",
      "command": "npm --prefix apps/canvas run build",
      "problemMatcher": []
    },
    {
      "label": "canvas dev",
      "type": "shell",
      "command": "npm --prefix apps/canvas run dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:.*"
        }
      }
    },
    {
      "label": "pytest",
      "type": "shell",
      "command": "UV_CACHE_DIR=.uv-cache uv run pytest",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "ruff",
      "type": "shell",
      "command": "UV_CACHE_DIR=.uv-cache uv run ruff check packages apps tests",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "polymath smoke",
      "type": "shell",
      "command": "printf '/quit\\n' | POLYMATH_OPEN_BROWSER=false UV_CACHE_DIR=.uv-cache uv run polymath explore 'Attention Is All You Need' --premise 'self-attention replaces recurrence as the core sequence modeling mechanism' --no-browser --port 8766",
      "problemMatcher": []
    }
  ]
}

